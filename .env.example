# ============================================
# APPLICATION DE GESTION DE CIMETIÈRE
# Modèle de variables d'environnement
# ============================================
# 📋 INSTRUCTIONS :
# 1. Copier ce fichier vers .env : cp .env.example .env
# 2. Modifier les valeurs dans .env avec vos propres informations
# 3. Ne JAMAIS commiter .env dans Git (seulement .env.example)

# ============================================
# DJANGO CONFIGURATION
# ============================================

# Clé secrète Django (GÉNÉRER UNE NOUVELLE CLÉ)
# Commande : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=votre-cle-secrete-ici

# Mode debug (True en développement, False en production)
DEBUG=True

# Hôtes autorisés (séparés par des virgules)
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# BASE DE DONNÉES POSTGRESQL + POSTGIS
# ============================================

DB_NAME=cimetiere_db
DB_USER=postgres
DB_PASSWORD=votre-mot-de-passe-postgres
DB_HOST=localhost
DB_PORT=5432

# ============================================
# CONFIGURATION EMAIL
# ============================================

# Backend email
# Développement : django.core.mail.backends.console.EmailBackend
# Production : django.core.mail.backends.smtp.EmailBackend ou anymail.backends.mailgun.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Configuration SMTP (pour production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-app
EMAIL_USE_TLS=True

# Email expéditeur par défaut
DEFAULT_FROM_EMAIL=noreply@cimetiere.local

# ============================================
# MAILGUN (Service d'envoi d'emails)
# ============================================

MAILGUN_API_KEY=votre-cle-api-mailgun
MAILGUN_SENDER_DOMAIN=votre-domaine.mailgun.org

# ============================================
# FRONTEND CONFIGURATION
# ============================================

API_BASE_URL=http://localhost:8000/api

# ============================================
# SÉCURITÉ (Production uniquement)
# ============================================

# Décommenter en production
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=INFO
LOG_FILE=logs/audit.log

# ============================================
# AUTRES CONFIGURATIONS
# ============================================

TIME_ZONE=Africa/Kinshasa
LANGUAGE_CODE=fr-fr
SESSION_COOKIE_AGE=1209600